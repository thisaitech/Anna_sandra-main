# Firebase Configuration
# Get these values from your Firebase Console:
# https://console.firebase.google.com/ -> Project Settings -> General

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Cloud Functions (optional)
VITE_FUNCTIONS_REGION=us-central1
VITE_FUNCTIONS_EMULATOR=false
VITE_FUNCTIONS_EMULATOR_HOST=localhost
VITE_FUNCTIONS_EMULATOR_PORT=5001

# Razorpay (public key only, optional for client checkout)
VITE_RAZORPAY_KEY_ID=your_razorpay_public_key_id

# NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_public_key_id
# RAZORPAY_KEY_SECRET=set-only-in-functions-secret-manager
